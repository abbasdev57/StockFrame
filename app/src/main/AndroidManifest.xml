<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- Required for any Firebase network call (Auth, Firestore, Storage) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Lets the OS/Firebase SDK detect connectivity state changes — used
         internally by Firestore's offline persistence layer, relevant
         once Sprint 4's offline support is built. -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".StockframeApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.StockFrame">
        <activity
            android:name=".MainActivity"
            android:exported="true"

            android:theme="@style/Theme.StockFrame">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <!-- Disable Firebase automatic data collection if you want minimal data footprint -->
        <meta-data
            android:name="firebase_analytics_collection_enabled"
            android:value="false" />
    </application>

</manifest>